Options -MultiViews
RewriteEngine On
RewriteBase /

# Serve mailer.php as PHP (not routed through React)
RewriteRule ^mailer\.php$ - [L]

# If the request is for an existing file or directory, serve it directly
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Otherwise, route all requests to index.html (React SPA)
RewriteRule ^ index.html [QSA,L]
